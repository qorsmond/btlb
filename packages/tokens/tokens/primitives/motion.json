{
  "motion": {
    "duration": {
      "$type": "duration",
      "instant": { "$value": "0ms" },
      "fast": { "$value": "150ms" },
      "base": { "$value": "250ms" },
      "slow": { "$value": "350ms" },
      "slower": { "$value": "500ms" }
    },
    "easing": {
      "$type": "cubicBezier",
      "linear": { "$value": [0, 0, 1, 1] },
      "in": { "$value": [0.4, 0, 1, 1] },
      "out": { "$value": [0, 0, 0.2, 1] },
      "inOut": { "$value": [0.4, 0, 0.2, 1] },
      "spring": { "$value": [0.34, 1.56, 0.64, 1] }
    }
  }
}
